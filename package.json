{
  "name": "qwencoder-mac-studio",
  "version": "1.0.1",
  "description": "QwenCoder Mac Studio — local MLX vision server + vibe coding",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac --dir",
    "dist": "electron-builder --mac",
    "test": "node --test 'test/*.test.js'"
  },
  "build": {
    "appId": "com.qwencoder.macstudio",
    "productName": "QwenCoder Mac Studio",
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "assets/icon.icns",
      "hardenedRuntime": true,
      "entitlements": "entitlements.mac.plist",
      "entitlementsInherit": "entitlements.mac.plist",
      "signIgnore": [
        "node_modules/xcodebuildmcp/bundled"
      ],
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ]
    },
    "files": [
      "main.js",
      "main/**/*",
      "preload.js",
      "setup.html",
      "requirements.txt",
      "config.js",
      "direct-bridge.js",
      "agent-pool.js",
      "orchestrator.js",
      "task-graph.js",
      "spec-workflow.js",
      "lsp-manager.js",
      "calibrator.js",
      "compactor.js",
      "compactor-builtin.js",
      "memory-client.js",
      "assist-client.js",
      "playwright-tool.js",
      "web-tools.js",
      "desktop-tool.js",
      "vision-tool.js",
      "ast-search.js",
      "search-worker.js",
      "steering-loader.js",
      "steering-generator.js",
      "project-map-generator.js",
      "projects.js",
      "xcode-tool.js",
      "telegram-bot.js",
      "telegram-miniapp-server.js",
      "recording-manager.js",
      "remote-job-controller.js",
      "robin-router.js",
      "vendor/**/*",
      "renderer/**/*",
      "assets/**/*",
      "node_modules/**/*",
      "!node_modules/electron/**",
      "!node_modules/electron-builder/**",
      "!node_modules/fast-check/**"
    ],
    "asarUnpack": [
      "node_modules/sharp/**",
      "node_modules/node-pty/**"
    ],
    "extraResources": [
      {
        "from": "server.py",
        "to": "server.py"
      },
      {
        "from": "compactor-bridge.py",
        "to": "compactor-bridge.py"
      },
      {
        "from": "memory-bridge.py",
        "to": "memory-bridge.py"
      },
      {
        "from": "telegram-miniapp.html",
        "to": "telegram-miniapp.html"
      },
      {
        "from": "resources/bin/",
        "to": "bin/",
        "filter": [
          "sg",
          "ast-grep",
          "agent-lsp"
        ]
      }
    ]
  },
  "dependencies": {
    "@qwen-code/sdk": "^0.1.6",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "chokidar": "^5.0.0",
    "node-pty": "^1.1.0",
    "openai": "^4.0.0",
    "playwright": "^1.59.1",
    "robotjs": "^0.6.0",
    "screenshot-desktop": "^1.15.0",
    "sharp": "^0.34.5",
    "ws": "^8.20.0",
    "xcodebuildmcp": "2.3.2"
  },
  "devDependencies": {
    "electron": "^41.3.0",
    "electron-builder": "^26.0.12",
    "fast-check": "^4.7.0"
  }
}
